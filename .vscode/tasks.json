{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run - JavaScript",
      "type": "shell",
      "command": "node '${file}' < '${workspaceFolder}/input.txt' > '${workspaceFolder}/output.txt'",
      "options": { "cwd": "${fileDirname}" },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
